{
  "name": "backup-disaster-recovery",
  "version": "1.0.0",
  "description": "Backup and disaster recovery tooling for Railway infrastructure",
  "scripts": {
    "backup:postgres": "bash postgres-backup.sh",
    "backup:redis": "bash redis-backup.sh",
    "restore": "bash restore.sh",
    "scheduler": "ts-node src/backup-scheduler.ts",
    "scheduler:now": "ts-node src/backup-scheduler.ts --now",
    "test": "jest --config jest.config.js",
    "build": "tsc"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.33",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
