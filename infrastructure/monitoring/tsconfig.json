{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "skipLibCheck": true,
    "typeRoots": ["/usr/local/lib/node_modules/@types"]
  },
  "include": ["src"],
  "exclude": ["src/__tests__"]
}
